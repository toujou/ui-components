{
  "name": "@toujou/ui-components",
  "version": "1.0.0-alpha.0",
  "description": "Collection of web-components used in the toujou themes",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toujou/ui-components.git"
  },
  "author": "toujou",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/toujou/ui-components/issues"
  },
  "homepage": "https://github.com/toujou/ui-components#readme",
  "scripts": {
    "build": "NODE_ENV=production npm run build:lib && NODE_ENV=production npm run build:dist",
    "build:lib": "lerna run build:lib",
    "build:dist": "lerna run build:dist",
    "build:changed": "lerna run build --since --parallel",
    "test": "web-test-runner",
    "test:single-package": "web-test-runner ./packages/$PACKAGE_NAME/tests/*.test.ts",
    "watch-components": "lerna run watch",
    "release": "npm run lint:changed && npm run build:changed && lerna version --include-merged-tags --exact && lerna publish from-package",
    "generate": "node scripts/generate/index.js",
    "lint": "npx eslint packages",
    "lint:single-package": "npx eslint packages/${PACKAGE_NAME} --ext .ts,.tsx,.js,.jsx,.cjs,.mjs",
    "lint:changed": "lerna run lint --since",
    "postinstall": "patch-package",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@babel/core": "^7.12.9",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/preset-env": "^7.12.7",
    "@esm-bundle/chai": "^4.3.4",
    "@open-wc/testing": "^3.0.0-next.5",
    "@rollup/plugin-alias": "^3.1.1",
    "@rollup/plugin-babel": "^5.2.1",
    "@rollup/plugin-commonjs": "^16.0.0",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-node-resolve": "^10.0.0",
    "@rollup/plugin-replace": "^2.3.4",
    "@storybook/web-components-vite": "^10.3.5",
    "@types/mapbox-gl": "^2.7.10",
    "@typescript-eslint/eslint-plugin": "^5.52.0",
    "@typescript-eslint/parser": "^5.52.0",
    "@web/dev-server-esbuild": "^0.3.3",
    "@web/dev-server-rollup": "^0.3.21",
    "@web/test-runner": "^0.15.0",
    "@web/test-runner-playwright": "^0.11.1",
    "autoprefixer": "^10.4.13",
    "chalk": "^5.2.0",
    "cookie-store": "^4.0.0-next.2",
    "eslint": "^8.34.0",
    "eslint-plugin-storybook": "^10.3.5",
    "fs-extra": "^11.1.0",
    "lerna": "^6.4.1",
    "lit": "^2.0.0-rc.2",
    "outdent": "^0.8.0",
    "patch-package": "^8.0.0",
    "postcss": "^8.4.20",
    "postcss-cli": "^10.1.0",
    "postcss-import": "^15.1.0",
    "redux": "^4.0.5",
    "redux-thunk": "^2.3.0",
    "regenerator-runtime": "^0.13.3",
    "remark-gfm": "^4.0.1",
    "replace-in-file": "^6.3.5",
    "reselect": "^4.0.0",
    "rollup": "^2.33.3",
    "rollup-plugin-lit-css": "^2.0.3",
    "rollup-plugin-postcss": "^4.0.0",
    "rollup-plugin-postcss-lit": "^2.0.0",
    "rollup-plugin-summary": "^1.3.0",
    "rollup-plugin-terser": "^7.0.2",
    "sinon": "^15.2.0",
    "storybook": "^10.3.5",
    "vite": "^7.3.1",
    "vite-plugin-lit-css": "^2.2.2"
  },
  "dependencies": {
    "@storybook/addon-docs": "^10.3.5",
    "@webcomponents/shadycss": "^1.9.5"
  },
  "peerDependencies": {
    "@maplibre/maplibre-gl-geocoder": "^1.9.0",
    "body-scroll-lock": "^3.1.5",
    "flatpickr": "^4.6.13",
    "iframe-resizer": "^4.4.5",
    "lit": "^2.0.0-rc.2",
    "maplibre-gl": "^5.7.0",
    "maplibregl-mapbox-request-transformer": "^0.0.2",
    "redux": "^4.0.5",
    "redux-thunk": "^2.3.0",
    "reselect": "^4.0.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
