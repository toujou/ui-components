{
  "name": "@toujou/toujou-collection-load-more",
  "version": "3.15.2",
  "author": "toujou",
  "license": "MIT",
  "description": "The toujou-collection-load-more package of toujou ui components",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build:lib && npm run build:dist",
    "build:lib": "rollup --silent --config ../../rollup.config.js",
    "build:dist": "rollup --config ../../rollup.config.dist.js",
    "genPackagelock": "npm i --package-lock-only",
    "watch": "rollup --watch --silent --config ../../rollup.config.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toujou/ui-components.git",
    "directory": "packages/toujou-collection-load-more"
  },
  "dependencies": {
    "lit": "^2.0.0-rc.2",
    "tslib": "^2.5.0"
  },
  "keywords": [
    "toujou",
    "web-component"
  ]
}
