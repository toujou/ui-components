{
	"name": "@toujou/toujou-datepicker",
	"version": "3.14.0",
	"author": "toujou",
	"license": "MIT",
	"description": "The toujou-datepicker package of toujou ui components",
	"type": "module",
	"main": "./dist/toujou-datepicker.js",
	"module": "./src/toujou-datepicker.js",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
