{
  "name": "@toujou/toujou-map",
  "version": "2.0.6",
  "description": "Different webcomponents wo render a mapbox map",
  "main": "./dist/toujou-map.js",
  "module": "./src/toujou-map.js",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toujou/ui-components.git",
