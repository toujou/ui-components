{
	"compilerOptions": {
		"target": "es2018",
		"module": "esnext",
		"moduleResolution": "node",
		"noEmitOnError": true,
		"lib": [
			"es2017",
			"dom"
		],
		"strict": false,
		"esModuleInterop": false,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"noImplicitAny": false,
		"allowJs": true,
		"noEmit": true,
		"noUnusedLocals": true,
		"resolveJsonModule": true,
		"types": [
			"node",
			"mocha"
		]
	},
}
