{
	"compilerOptions": {
		"target": "es2018",
		"module": "esnext",
		"moduleResolution": "node",
		"noEmitOnError": true,
		"lib": [
			"es2017",
			"dom"
		],
		"strict": false,
		"esModuleInterop": false,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"noImplicitAny": false,
		"allowJs": true,
		"noEmit": true,
		"noUnusedLocals": true,
		"resolveJsonModule": true,
		"typeRoots": [
			"./node_modules/@types/",
			"./types/"
		],
		"types": [
			"node",
			"mocha",
			"css"
		]
	},
	"include": [
		"**/*.ts"
	]
}
