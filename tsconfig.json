{
	"compilerOptions": {
		"esModuleInterop": false,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"target": "es5",
		"module": "ESNext",
		"moduleResolution": "Node",
		"strict": true,
		"noImplicitAny": true,
		"allowJs": true,
		"noEmit": true,
		"noUnusedLocals": true,
		"resolveJsonModule": true,
		"types": [
			"node"
		]
	},
}
